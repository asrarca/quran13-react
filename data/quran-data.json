    { "num": 18, "name": "Juz 18", "arabicStart": "قَدْ أَفْلَحَ",          "page": 476 },
    { "num": 19, "name": "Juz 19", "arabicStart": "وَقَالَ الَّذِينَ",        "page": 504 },
    { "num": 20, "name": "Juz 20", "arabicStart": "أَمَّنْ خَلَقَ",          "page": 532 },
    { "num": 21, "name": "Juz 21", "arabicStart": "اتْلُ مَآ أُوحِيَ",       "page": 558 },
