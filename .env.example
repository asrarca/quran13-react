# =============================================================================
# Quran 13 — environment variables (TEMPLATE)
# =============================================================================
# Copy this file to `.env.local` and fill in real values for local dev.
# `.env.local` is gitignored; this template is committed so the required
# variables are documented. For production, set the same keys in your host's
# dashboard (e.g. Vercel → Project → Settings → Environment Variables) or in
# `.env.production.local`.
#
# NOTE: None of these are prefixed NEXT_PUBLIC_ — they are SERVER-ONLY secrets.
# They are read in Node scripts and Next.js route handlers, never shipped to
# the browser. Do not add NEXT_PUBLIC_ to the client id/secret.
# =============================================================================

# --- Quran Foundation API (formerly the open Quran.com API) -------------------
# Register for credentials at: https://api-docs.quran.foundation  (request access)
# You get TWO credential sets: one for the "prelive" (sandbox) environment used
# in dev, and one for "production". Point the *_BASE URLs at the matching pair.
#
#   DEV  (prelive):  QF_AUTH_BASE=https://prelive-oauth2.quran.foundation
#                    QF_API_BASE=https://apis-prelive.quran.foundation
#   PROD (live):     QF_AUTH_BASE=https://oauth2.quran.foundation
#                    QF_API_BASE=https://apis.quran.foundation

QF_CLIENT_ID=your-client-id-here
QF_CLIENT_SECRET=your-client-secret-here
QF_AUTH_BASE=https://prelive-oauth2.quran.foundation
QF_API_BASE=https://apis-prelive.quran.foundation

# --- LLM provider for the natural-language navigation agent (LangChain) --------
# Used server-side by the agent route. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
